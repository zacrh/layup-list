#!/usr/bin/env bash
set -eo pipefail

# make sure we have a build directory
mkdir -p "$BUILD_DIR/.heroku/vendor"

# make sure npm is available — should be
export PATH="$BUILD_DIR/.heroku/vendor/node/bin:$PATH"

npm install -g yuglify

# add to path
export PATH="$BUILD_DIR/.heroku/vendor/bin:$PATH"
echo "Yuglify installed at: $(which yuglify)"